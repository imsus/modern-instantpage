{
  "name": "@imsus/modern-instantpage",
  "version": "6.0.0",
  "description": "Make your site's pages instant in 1 minute — modernized fork of instant.page with TypeScript, Speculation Rules API, and PointerEvent",
  "type": "module",
  "main": "dist/instantpage.min.js",
  "module": "dist/instantpage.es.js",
  "types": "dist/instantpage.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/instantpage.d.ts",
        "default": "./dist/instantpage.es.js"
      },
      "require": {
        "types": "./dist/instantpage.d.ts",
        "default": "./dist/instantpage.min.js"
      }
    },
    "./debug": {
      "import": "./dist/instantpage-debug.es.js",
      "require": "./dist/instantpage-debug.min.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --config vite.debug.config.ts",
    "build:prod": "vite build",
    "build:debug": "vite build --config vite.debug.config.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imsus/modern-instantpage.git"
  },
  "keywords": [
    "instant",
    "performance",
    "prefetch",
    "speculation-rules",
    "prerender",
    "page-load",
    "speed",
    "core-web-vitals"
  ],
  "author": "Alexandre Dieulot, imsus",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/imsus/modern-instantpage/issues"
  },
  "homepage": "https://github.com/imsus/modern-instantpage#readme",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "terser": "^5.48.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
